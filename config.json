{
  "fields": [
    {
      "key": "project",
      "prefix_until_keywords": [
        "海悦银河城",
        "樊华似锦2期",
        "壹北栋",
        "金瑞特酒店",
        "东方华庭",
        "樊华广场",
        "学院",
        "卓信金楠天街",
        "镇",
        "文泉天筑",
        "樊华似锦",
        "富乐国际初中",
        "医院"
      ],
      "fallback": ""
    },
    {
      "key": "area",
      "label": "施工区域",
      "fallback": ""
    },
    {
      "key": "date",
      "regex": "(20\\d{2}[./-]\\d{1,2}[./-]\\d{1,2})",
      "fallback": ""
    },
    {
      "key": "datetime",
      "regex": "(20\\d{2}[./-]\\d{1,2}[./-]\\d{1,2}\\s+\\d{1,2}:\\d{2})",
      "fallback": ""
    },
    {
      "key": "content",
      "label": "施工内容",
      "fallback": ""
    }
  ],
  "filename_template": "{project}_{area}_{datetime}_{content}",
  "folder_template": "{project}/{area}/{date}/{content}",
  "stop_labels": [
    "施工区域",
    "施工内容",
    "天气",
    "地点"
  ],
  "ignore_words": [
    "水印",
    "相机"
  ],
  "default_date": "2026.05.12",
  "enable_default_date": false,
  "enable_stop_label_match": false,
  "avoid_keyword_fields": [
    "area",
    "content"
  ]
}