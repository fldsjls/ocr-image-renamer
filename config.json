{
  "fields": [
    {
      "key": "area",
      "label": "施工区域",
      "fallback": "未识别区域"
    },
    {
      "key": "date",
      "regex": "(20\\d{2}[./-]\\d{1,2}[./-]\\d{1,2})",
      "fallback": "未识别日期"
    },
    {
      "key": "datetime",
      "regex": "(20\\d{2}[./-]\\d{1,2}[./-]\\d{1,2}\\s+\\d{1,2}:\\d{2})",
      "fallback": "未识别时间"
    },
    {
      "key": "content",
      "label": "施工内容",
      "fallback": "未识别内容"
    }
  ],
  "filename_template": "{area}_{datetime}_{content}",
  "folder_template": "{area}/{date}/{content}",
  "stop_labels": [
    "施工区域",
    "施工内容",
    "天气",
    "地点"
  ]
}
